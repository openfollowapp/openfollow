# OpenFollow kanshi output layout (loaded via `kanshi -c`).
#
# Mirror every connected HDMI output so the followspot view shows on all
# screens. Both outputs are placed at position 0,0 (overlapping = mirrored).
#
# Mode is pinned to 1920x1080: the on-screen UI (Cairo HUD) is drawn at fixed
# pixel sizes with no output-scale awareness, so on a 4K panel (preferred mode
# 3840x2160) the whole UI renders at ~half size. 1080p is the followspot target
# resolution (the video source is 1080p) and matches the Ansible deploy, which
# pins a fixed mode per install. A panel without a 1080p mode falls back to its
# preferred mode by kanshi's normal handling.
#
# kanshi matches the first profile whose named outputs exactly equal the set of
# connected outputs: `dual` when both HDMI ports are connected, otherwise the
# matching single-output profile.
profile dual {
	output HDMI-A-1 mode 1920x1080 position 0,0 enable
	output HDMI-A-2 mode 1920x1080 position 0,0 enable
}
profile single-1 {
	output HDMI-A-1 mode 1920x1080 enable
}
profile single-2 {
	output HDMI-A-2 mode 1920x1080 enable
}
